# Copy to `.env.local` to override during `npm run dev`.
#
# Local dev (default): omit this file — Vite proxies /api → http://localhost:3000
#
# Local dev against Render:
# VITE_API_BASE_URL=https://tracking-indiapost.onrender.com
#
# Production builds use `.env.production` (same URL as below).

VITE_API_BASE_URL=https://tracking-indiapost.onrender.com
