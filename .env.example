PORT=3000
NODE_ENV=development

# India Post (Customer Self-Service Portal) credentials
INDIAPOST_USERNAME=1234567890
INDIAPOST_PASSWORD=Dop@1234

# Optional: if you already have tokens, you can set these (app will refresh when needed)
INDIAPOST_ACCESS_TOKEN=
INDIAPOST_REFRESH_TOKEN=

# Default upstream base URL (keep as-is unless India Post changes it)
INDIAPOST_BASE_URL=https://app.indiapost.gov.in

# Large batches — JSON body size (Express), max consignments per request, HTTP timeouts
JSON_BODY_LIMIT=10mb
MAX_CONSIGNMENTS=100000
SERVER_REQUEST_TIMEOUT_MS=900000
INDIAPOST_HTTP_TIMEOUT_MS=60000

# Upstream bulk calls are chunked (50 articles/request). Tune parallelism / pacing:
INDIAPOST_CHUNK_CONCURRENCY=1
INDIAPOST_CHUNK_DELAY_MS=0
# INDIAPOST_LOG_CHUNKS=1

# Full ZIP export jobs (server-side queue, one job runs at a time)
EXPORT_FULL_PDF_GAP_MS=75
EXPORT_FULL_JOB_TTL_MS=1800000
EXPORT_FULL_MAX_JOBS=40

