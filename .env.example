PORT=3000
NODE_ENV=development

# India Post (Customer Self-Service Portal) credentials
INDIAPOST_USERNAME=1234567890
INDIAPOST_PASSWORD=Dop@1234

# Optional: if you already have tokens, you can set these (app will refresh when needed)
INDIAPOST_ACCESS_TOKEN=
INDIAPOST_REFRESH_TOKEN=

# Default upstream base URL (keep as-is unless India Post changes it)
INDIAPOST_BASE_URL=https://app.indiapost.gov.in

# Large batches — JSON body size (Express), max consignments per request, HTTP timeouts
JSON_BODY_LIMIT=10mb
MAX_CONSIGNMENTS=100000
SERVER_REQUEST_TIMEOUT_MS=900000
INDIAPOST_HTTP_TIMEOUT_MS=60000

# Upstream bulk calls are chunked (50 articles/request). Tune parallelism / pacing:
INDIAPOST_CHUNK_CONCURRENCY=1
INDIAPOST_CHUNK_DELAY_MS=0
# INDIAPOST_LOG_CHUNKS=1

# Full ZIP export jobs (server-side queue, one job runs at a time)
EXPORT_FULL_PDF_GAP_MS=75
EXPORT_FULL_JOB_TTL_MS=1800000
EXPORT_FULL_MAX_JOBS=40

# Public share links for full ZIP (no login on /share/:token)
EXPORT_SHARE_TTL_MS=1800000

# MongoDB — share download links (token → export job)
MONGODB_URI=mongodb://127.0.0.1:27017
MONGODB_DB_NAME=indiapost_tracking

# Auth (required in production)
JWT_SECRET=change-me-to-a-long-random-string

# User store — on Vercel use /tmp (ephemeral; redeploys reset users unless you use external storage)
# USER_STORE_PATH=/tmp/users.json

# --- Vercel deployment ---
# Set these in Project → Settings → Environment Variables (Production + Preview).
# VERCEL is set automatically on Vercel (enables trust proxy for rate limiting).
# TRUST_PROXY=1 — same on other hosts behind nginx, Cloudflare, etc.
# The React app calls /api by default (VITE_API_BASE_URL optional).
# Vercel Hobby: function max 60s — use Pro for long bulk exports (vercel.json sets maxDuration 300).
# Full ZIP export jobs are in-memory per instance; large exports are more reliable on a long-running Node host.

